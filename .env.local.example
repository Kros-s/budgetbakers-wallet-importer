# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# BudgetBakers CouchDB (direct credentials)
COUCH_URL=https://couch-prod-us-1.budgetbakers.com
COUCH_DB=bb-your-user-id-here
COUCH_LOGIN=your-user-id-uuid
COUCH_TOKEN=your-replication-token
COUCH_USER_ID=your-user-id-uuid

# Webhook server
WEBHOOK_SECRET=generate_with_openssl_rand_hex_32
WEBHOOK_PORT=8765

# iCloud IMAP poller (optional — omit to disable)
# App-specific password: appleid.apple.com → Security → App Passwords
ICLOUD_EMAIL=you@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
IMAP_POLL_INTERVAL_MS=120000
IMAP_LOOKBACK_DAYS=3
